# ── LLM Provider ──────────────────────────────────────────────
# Set to "lmstudio" for local dev, "groq" for HuggingFace deployment
LLM_PROVIDER=lmstudio

# ── LM Studio (local dev — FREE) ──────────────────────────────
# Start LM Studio → Local Server tab → click Start
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF

# ── Groq (HuggingFace deployment — FREE tier) ─────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./vectorstore/chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# ── Embeddings (local, no API key needed) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# ── Retrieval settings ─────────────────────────────────────────
TOP_K_RETRIEVAL=10
TOP_K_RERANK=4
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Optional: LangSmith tracing ───────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=enterprise-rag
